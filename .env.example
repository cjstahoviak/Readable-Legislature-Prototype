# Free key from https://api.data.gov (used for the Congress.gov API).
CONGRESS_API_KEY=

# Claude API key from https://console.anthropic.com. The pipelines read
# PIPELINE_ANTHROPIC_API_KEY first, then fall back to ANTHROPIC_API_KEY —
# use the PIPELINE_ name in Claude Code cloud environments, which reserve
# ANTHROPIC_API_KEY for session auth and withhold it from the container.
PIPELINE_ANTHROPIC_API_KEY=

# PostgreSQL connection string. The default matches docker-compose.yml;
# point it at Neon (pooled connection string) in production. dbmate and
# the pipelines both read this.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/readable_legislature?sslmode=disable
